<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="12dp"
    android:paddingHorizontal="16dp"
    android:background="?attr/selectableItemBackground">

    <TextView
        android:id="@+id/ticker"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/primaryValue"
        app:layout_constraintHorizontal_bias="0"
        tools:text="AAPL" />

    <TextView
        android:id="@+id/typeCurrency"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:alpha="0.7"
        android:layout_marginTop="2dp"
        app:layout_constraintTop_toBottomOf="@id/ticker"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/subValue"
        app:layout_constraintHorizontal_bias="0"
        tools:text="STOCK · USD" />

    <TextView
        android:id="@+id/primaryValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="2,750.00 USD" />

    <TextView
        android:id="@+id/subValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:alpha="0.7"
        android:layout_marginTop="2dp"
        app:layout_constraintTop_toBottomOf="@id/primaryValue"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="10 × cost 2,500.00" />

    <TextView
        android:id="@+id/pnl"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:textStyle="bold"
        android:layout_marginTop="2dp"
        app:layout_constraintTop_toBottomOf="@id/subValue"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="+250.00 (+10.0%)"
        tools:textColor="@color/pnl_positive" />

</androidx.constraintlayout.widget.ConstraintLayout>
